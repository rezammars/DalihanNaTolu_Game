  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: dcc396ea8f68c7a48ba97646c138b1d3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  teksNama: {fileID: 1338653280}
  teksDialog: {fileID: 1338653279}
  panelDialog: {fileID: 1338653281}
  teksCutscene: {fileID: 1846437563}
  overlayGelap: {fileID: 907220485}
  bubbleNPC_A: {fileID: 529503045}
  teksBubbleA: {fileID: 440272528}
  bubbleNPC_B: {fileID: 90464761}
  teksBubbleB: {fileID: 1958397413}
  namaNPC_A: NPC A
  namaNPC_B: NPC B
  semuaNama:
  - 
  - NPC A
  - NPC B
  - Alfredo
  - Tetua Adat
  semuaDialog:
  - 'Hari ini suasana desa terasa berbeda.

    Beberapa orang mulai berselisih,
    dan prosesi tidak berjalan lancar.

    Untuk pertama kalinya, aku harus mengambil
    keputusan sendiri.'
  - Kami seharusnya didahulukan!
  - Itu bukan keputusanmu!
  - "Kenapa semuanya jadi ribut begini\u2026 \nAku harus lakukan sesuatu untuk memperbaiki
    suasana hati semua orang, agar acaranya bisa segera dilaksanakan sesuai adat"
  - 'Ingat, untuk menyelesaikan masalah ini kamu harus tau adat bukan hanya aturan.

    Adat
    juga tentang menjaga perasaan orang lain/'
  semuaKarakter:
  - namaKarakter: Alfredo
    gambarKarakter: {fileID: 1674332855}
  - namaKarakter: Tetua Adat
