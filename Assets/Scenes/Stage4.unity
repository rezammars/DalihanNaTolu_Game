  m_Script: {fileID: 11500000, guid: dcc396ea8f68c7a48ba97646c138b1d3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  nameText: {fileID: 1301897552}
  dialogText: {fileID: 1824087751}
  dialogPanel: {fileID: 2106441074}
  cutsceneText: {fileID: 1855373584}
  names:
  - Tetua Adat
  - Alfredo
  - 
  - 
  - 
  - 
  dialogs:
  - "Kau sudah memahami arti Dalihan Na Tolu.\nBukan sekadar aturan\u2026 tapi cara
    menjaga hubungan."
  - 'Sekarang aku mengerti.

    Adat bukan sesuatu yang membatasi.

    Adat menjaga
    agar semua tetap seimbang.'
  - Aku datang ke desa ini tanpa benar-benar memahami adatku sendiri.
  - "Tapi dari setiap peran, setiap konflik, dan setiap prosesi\u2026"
  - Aku belajar bahwa Dalihan Na Tolu bukan hanya tradisi.
  - 'Ini adalah cara untuk saling menghormati dan menjaga kebersamaan.

    Dan sekarang,
    aku bukan lagi sekadar penonton.

    Aku sudah menjadi bagian dari itu.'
  characters:
  - characterName: Alfredo
    characterImage: {fileID: 1029032888}
  - characterName: Tetua Adat
    characterImage: {fileID: 1211040128}
  onFinished:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 0}
        m_TargetAssemblyTypeName: FlowPanel, Assembly-CSharp
        m_MethodName: ShowStep
        m_Mode: 3
